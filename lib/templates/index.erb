<header class="site-header">
  <div class="header-row">
<% if cover_url %>
    <img class="header-cover" src="<%= cover_url %>" alt="<%= podcast_title %>">
<% end %>
    <div class="header-text">
      <h1><%= podcast_title %><% if feed_url %> <a class="rss-link" href="<%= feed_url %>" title="RSS Feed"><svg class="feed-icon" width="18" height="18" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 256 256"><defs><linearGradient x1=".085" y1=".085" x2=".915" y2=".915" id="g"><stop offset="0" stop-color="#E3702D"/><stop offset=".107" stop-color="#EA7D31"/><stop offset=".35" stop-color="#F69537"/><stop offset=".5" stop-color="#FB9E3A"/><stop offset=".702" stop-color="#EA7C31"/><stop offset=".887" stop-color="#DE642B"/><stop offset="1" stop-color="#D95B29"/></linearGradient></defs><rect width="256" height="256" rx="55" ry="55" fill="#CC5D15"/><rect x="4" y="4" width="248" height="248" rx="50" ry="50" fill="url(#g)"/><circle cx="68" cy="189" r="24" fill="#FFF"/><path d="M160 213h-34a82 82 0 0 0-82-82V97a116 116 0 0 1 116 116z" fill="#FFF"/><path d="M184 213A140 140 0 0 0 44 73V38a175 175 0 0 1 175 175z" fill="#FFF"/></svg></a><% end %></h1>
<% if podcast_description %>
      <p class="description"><%= podcast_description %></p>
<% end %>
    </div>
  </div>
</header>
<ul class="episode-list">
<% episodes.each do |ep| %>
  <li class="episode-item">
<% if ep[:thumb_url] %>
    <a href="<%= ep[:page_path] %>"><img class="episode-thumb" src="<%= ep[:thumb_url] %>" alt=""></a>
<% end %>
    <div class="episode-content">
      <div class="episode-meta"><%= ep[:date] %><% if ep[:duration] && site_config.fetch(:show_duration, true) %> &middot; <%= ep[:duration] %><% end %></div>
      <a class="episode-title" href="<%= ep[:page_path] %>"><%= ep[:title] %></a>
      <audio controls preload="metadata" src="<%= ep[:audio_url] %>"></audio>
    </div>
  </li>
<% end %>
</ul>
