<!DOCTYPE html>
<html lang="<%= lang %>">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= page_title %></title>
<% if favicon_path %>
  <link rel="icon" href="<%= favicon_path %>">
<% end %>
  <link rel="stylesheet" href="<%= css_path %>">
<% unless site_config.empty? %>
  <style>
    :root {
<% if site_config[:accent] %>
      --accent: <%= site_config[:accent] %>;
      --accent-hover: <%= site_config[:accent] %>;
<% end %>
<% if site_config[:bg] %>
      --bg: <%= site_config[:bg] %>;
<% end %>
<% if site_config[:radius] %>
      --radius: <%= site_config[:radius] %>;
<% end %>
<% if site_config[:max_width] %>
      --max-w: <%= site_config[:max_width] %>;
<% end %>
    }
<% if site_config[:accent_dark] || site_config[:bg_dark] %>
    @media (prefers-color-scheme: dark) {
      :root {
<% if site_config[:accent_dark] %>
        --accent: <%= site_config[:accent_dark] %>;
        --accent-hover: <%= site_config[:accent_dark] %>;
<% end %>
<% if site_config[:bg_dark] %>
        --bg: <%= site_config[:bg_dark] %>;
<% end %>
      }
    }
<% end %>
  </style>
<% end %>
<% if custom_css_path %>
  <link rel="stylesheet" href="<%= custom_css_path %>">
<% end %>
</head>
<body>
  <div class="container">
    <%= content %>
    <footer class="site-footer">
      <%= footer_text %>
    </footer>
  </div>
  <script>
  document.addEventListener('play', function(e) {
    document.querySelectorAll('audio').forEach(function(a) {
      if (a !== e.target) a.pause();
    });
  }, true);
  (function() {
    var speeds = [1.2, 1.1, 1, 0.95, 0.9, 0.85, 0.8, 0.75];
    var def = <%= site_config.fetch(:playback_speed, 1) %>;
    var rawSaved = parseFloat(localStorage.getItem('playbackRate'));
    var saved = isNaN(rawSaved) ? def : rawSaved;
    // Snap saved value to the nearest allowlisted speed so the <select>
    // displayed value matches the actual playbackRate.
    var snapped = speeds.reduce(function(best, s) {
      return Math.abs(s - saved) < Math.abs(best - saved) ? s : best;
    }, speeds[0]);
    saved = snapped;
    document.querySelectorAll('audio').forEach(function(a) { a.playbackRate = saved; });
    document.querySelectorAll('.speed-selector').forEach(function(sel) {
      speeds.forEach(function(s) {
        var opt = document.createElement('option');
        opt.value = s;
        opt.textContent = s === 1 ? '1x' : s + 'x';
        if (s === saved) opt.selected = true;
        sel.appendChild(opt);
      });
    });
    document.addEventListener('change', function(e) {
      if (!e.target.classList.contains('speed-selector')) return;
      var rate = parseFloat(e.target.value);
      localStorage.setItem('playbackRate', rate);
      document.querySelectorAll('audio').forEach(function(a) { a.playbackRate = rate; });
      document.querySelectorAll('.speed-selector').forEach(function(s) { s.value = rate; });
    });
  })();
  document.addEventListener('click', function(e) {
    var btn = e.target.closest('.vocab-lang-switcher button');
    if (!btn) return;
    var lang = btn.getAttribute('data-vocab-lang');
    document.querySelectorAll('.vocab-lang-switcher button').forEach(function(b) {
      b.classList.toggle('active', b.getAttribute('data-vocab-lang') === lang);
    });
    document.querySelectorAll('[data-vocab-lang]').forEach(function(el) {
      if (!el.closest('.vocab-lang-switcher')) {
        el.classList.toggle('active', el.getAttribute('data-vocab-lang') === lang);
      }
    });
  });
  // Vocab tooltip positioning: shift the bubble inside the viewport when its
  // word sits near a screen edge, and move the arrow so it still points at
  // the word's center.
  function positionVocabTip(word) {
    var tip = word.querySelector('.vocab-tip');
    if (!tip) return;
    tip.style.left = '';
    tip.style.transform = '';
    tip.style.setProperty('--vocab-tip-arrow-x', '50%');
    tip.classList.remove('below');

    var rect = tip.getBoundingClientRect();
    if (rect.width === 0) return; // not displayed yet

    var pad = 8;
    var vw = window.innerWidth;
    var vh = window.innerHeight;
    var wordRect = word.getBoundingClientRect();
    var wordCenter = wordRect.left + wordRect.width / 2;

    // Horizontal: center on word, then clamp into viewport [pad, vw - pad]
    var desiredLeft = wordCenter - rect.width / 2;
    var clampedLeft = Math.max(pad, Math.min(vw - pad - rect.width, desiredLeft));
    if (Math.abs(clampedLeft - desiredLeft) > 0.5) {
      tip.style.left = (clampedLeft - wordRect.left) + 'px';
      tip.style.transform = 'none';
      var arrowX = Math.max(8, Math.min(rect.width - 8, wordCenter - clampedLeft));
      tip.style.setProperty('--vocab-tip-arrow-x', arrowX + 'px');
    }

    // Vertical: pick the side with more room
    var spaceAbove = wordRect.top - pad;
    var spaceBelow = vh - wordRect.bottom - pad;
    var aboveFits = rect.height <= spaceAbove;
    var belowFits = rect.height <= spaceBelow;
    if (!aboveFits && belowFits) {
      tip.classList.add('below');
    } else if (!aboveFits && !belowFits && spaceBelow > spaceAbove) {
      tip.classList.add('below');
    }

    // Defensive re-check: if anything in the layout shifted between measurements,
    // force the bubble back into the viewport.
    var finalRect = tip.getBoundingClientRect();
    var currentInline = parseFloat(tip.style.left) || 0;
    if (finalRect.right > vw - pad) {
      tip.style.left = (currentInline - (finalRect.right - (vw - pad))) + 'px';
      tip.style.transform = 'none';
    } else if (finalRect.left < pad) {
      tip.style.left = (currentInline + (pad - finalRect.left)) + 'px';
      tip.style.transform = 'none';
    }
  }

  // Vocab tooltip on touch: first tap previews, second tap navigates.
  // Gated by pointerType on the click event itself — works on pure-touch
  // devices AND hybrids (laptop with touch screen, iPad with trackpad).
  document.addEventListener('click', function(e) {
    if (e.pointerType !== 'touch') return;
    var word = e.target.closest('.vocab-word');
    if (word) {
      if (!word.classList.contains('show-tip')) {
        e.preventDefault();
        document.querySelectorAll('.vocab-word.show-tip').forEach(function(w) {
          if (w !== word) w.classList.remove('show-tip');
        });
        word.classList.add('show-tip');
        positionVocabTip(word);
      }
    } else {
      document.querySelectorAll('.vocab-word.show-tip').forEach(function(w) {
        w.classList.remove('show-tip');
      });
    }
  });

  // Desktop hover: CSS :hover continues to control display; we only adjust
  // position to keep the bubble inside the viewport.
  document.addEventListener('mouseover', function(e) {
    var word = e.target.closest && e.target.closest('.vocab-word');
    if (word) positionVocabTip(word);
  });
  </script>
</body>
</html>
