#!/usr/bin/env ruby
# frozen_string_literal: true

# tell — Pronounce text via ElevenLabs TTS with auto-translation
# Part of the podgen toolkit

code_root = File.expand_path("..", __dir__)

# Bundler setup — only when running from a git clone (Gemfile present)
gemfile = File.join(code_root, "Gemfile")
if File.exist?(gemfile)
  ENV["BUNDLE_GEMFILE"] ||= gemfile
  require "bundler/setup"
end

require "dotenv"
Dotenv.load(File.join(code_root, ".env"))

# Also load home directory .env if present
home_env = File.expand_path("~/.env")
Dotenv.load(home_env) if File.exist?(home_env)

history_file = File.expand_path("~/.tell_history")

save_history = -> {
  return unless defined?(Reline::HISTORY)
  entries = Reline::HISTORY.to_a.last(1000)
  if entries.any?
    File.write(history_file, entries.join("\n") + "\n")
  elsif File.exist?(history_file)
    File.delete(history_file)
  end
}

Signal.trap("INT")  { save_history.call; $stderr.puts; exit 130 }
Signal.trap("TERM") { save_history.call; exit 143 }

require "optparse"
require_relative File.join(code_root, "lib", "tell", "config")
require_relative File.join(code_root, "lib", "tell", "detector")
require_relative File.join(code_root, "lib", "tell", "translator")
require_relative File.join(code_root, "lib", "tell", "tts")
require_relative File.join(code_root, "lib", "tell", "glosser")
require_relative File.join(code_root, "lib", "tell", "processor")

output_path = nil
no_translate = false
overrides = {}

parser = OptionParser.new do |opts|
  opts.banner = "Usage: tell [options] [text...]"
  opts.separator ""
  opts.separator "Pronounce text via TTS (ElevenLabs or Google). Assumes input is in the"
  opts.separator "target language. Use -f to enable translation from another language."
  opts.separator ""

  opts.on("-f", "--from [LANG]", "Translate from LANG (auto-detect if omitted)") { |l| overrides[:translate_from] = l || "auto" }
  opts.on("-t", "--to LANG", "Override target language (e.g. ja)") { |l| overrides[:to] = l }
  opts.on("-e", "--engine NAME", "Override TTS engine (elevenlabs|google)") { |e| overrides[:tts_engine] = e }
  opts.on("-v", "--voice ID", "Override voice ID") { |v| overrides[:voice] = v }
  opts.on("-o", "--output FILE", "Save audio to FILE instead of playing") { |f| output_path = f }
  opts.on("-r", "--reverse", "Show reverse translation for target-language input") { overrides[:reverse] = true }
  opts.on("-g", "--gloss", "Show word-by-word grammatical analysis") { overrides[:gloss] = true }
  opts.on("--gr", "Gloss with word translations: word(grammar)translation") { overrides[:gloss_reverse] = true }
  opts.on("-n", "--no-translate", "Override config auto back to default (no translation)") { no_translate = true }
  opts.on("-h", "--help", "Show this help") { puts opts; exit }
end
parser.parse!

def delete_from_history(target)
  before = Reline::HISTORY.size
  Reline::HISTORY.delete(target)
  before - Reline::HISTORY.size
end

if !ARGV.empty? && ARGV.last.end_with?("/d")
  text = ARGV.join(" ")
  target = text.delete_suffix("/d").strip
  unless target.empty?
    if File.exist?(history_file)
      lines = File.readlines(history_file, chomp: true)
      before = lines.size
      lines.reject! { |h| h == target }
      if lines.empty?
        File.delete(history_file)
      else
        File.write(history_file, lines.join("\n") + "\n")
      end
      count = before - lines.size
      $stderr.puts "Deleted #{count} history entry#{"s" if count != 1}: #{target}"
    else
      $stderr.puts "No history file"
    end
  end
  exit
end

begin
  # -f with a real lang code also feeds into Config for reverse_translate direction
  if overrides[:translate_from] && overrides[:translate_from] != "auto"
    overrides[:from] = overrides[:translate_from]
  end

  config = Tell::Config.new(overrides: overrides)

  translate_from = if no_translate
                     nil
                   elsif overrides[:translate_from]
                     overrides[:translate_from]
                   elsif config.original_language == "auto"
                     "auto"
                   end

  interactive = ARGV.empty? && $stdin.tty?
  processor = Tell::Processor.new(config, interactive: interactive)

  if !ARGV.empty?
    text = ARGV.join(" ")

    # Append to persistent history (deduplicating)
    lines = File.exist?(history_file) ? File.readlines(history_file, chomp: true) : []
    lines.reject! { |h| h == text }
    lines << text
    File.write(history_file, lines.last(1000).join("\n") + "\n")

    processor.process(text, output_path: output_path, translate_from: translate_from)

  elsif !$stdin.tty?
    # Pipe mode: echo "hello" | tell
    text = $stdin.read
    processor.process(text, output_path: output_path, translate_from: translate_from) unless text.strip.empty?

  else
    # Interactive mode: readline for history (up/down) and line editing
    require "reline"

    # Load persistent history
    if File.exist?(history_file)
      File.readlines(history_file, chomp: true).each { |h| Reline::HISTORY << h }
    end

    # Reline overrides this during readline; outside readline (during API
    # calls) Ctrl-C raises Interrupt → caught by rescue → ensure saves.
    trap("INT") { raise Interrupt }

    last_entry = nil

    begin
      while (line = Reline.readline("", true))
        line = line.strip
        Reline::HISTORY.pop if line.empty?
        next if line.empty?

        # /d suffix or standalone: delete entry from history
        if line == "/d"
          Reline::HISTORY.pop  # remove "/d" itself
          if last_entry
            n = delete_from_history(last_entry)
            $stderr.puts Tell::Colors.status("Deleted #{n}: #{last_entry}")
            last_entry = nil
          end
          save_history.call
          next
        elsif line.end_with?("/d")
          Reline::HISTORY.pop  # remove "foo/d" itself
          target = line.delete_suffix("/d").strip
          unless target.empty?
            n = delete_from_history(target)
            $stderr.puts Tell::Colors.status("Deleted #{n}: #{target}")
          end
          save_history.call
          next
        end

        # Deduplicate: remove all older occurrences, keeping only the latest
        while (idx = Reline::HISTORY.to_a[0...-1].rindex(line))
          Reline::HISTORY.delete_at(idx)
        end

        last_entry = line
        save_history.call
        processor.process(line, output_path: output_path, translate_from: translate_from)
      end
    rescue Interrupt
      $stderr.puts
    ensure
      save_history.call
    end
  end

rescue => e
  $stderr.puts "tell: #{e.message}"
  exit 1
end
