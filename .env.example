ANTHROPIC_API_KEY=
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
EXA_API_KEY=
CLAUDE_MODEL=claude-opus-4-6
# Optional: Claude model for web search source (default: claude-haiku-4-5-20251001)
# CLAUDE_WEB_MODEL=claude-haiku-4-5-20251001
# Optional: Bluesky source (free, requires account)
BLUESKY_HANDLE=
BLUESKY_APP_PASSWORD=
# Optional: X/Twitter source via SocialData.tools (~$0.01/run)
SOCIALDATA_API_KEY=
# Optional: Language pipeline (transcription) and EN→JP translation (news pipeline)
OPENAI_API_KEY=
# WHISPER_MODEL=gpt-4o-mini-transcribe
# Optional: model used when a ## Language entry sets translator: openai (default: gpt-5)
# OPENAI_TRANSLATION_MODEL=gpt-5
# Optional: Groq transcription engine
# GROQ_API_KEY=
# GROQ_WHISPER_MODEL=whisper-large-v3
# Optional: ElevenLabs transcription model
# ELEVENLABS_SCRIBE_MODEL=scribe_v2
# Optional: LingQ upload
# LINGQ_API_KEY=
# Optional: YouTube support (browser for yt-dlp cookie auth)
# YOUTUBE_BROWSER=chrome
# Optional: YouTube upload (OAuth2 credentials from Google Cloud Console)
# YOUTUBE_CLIENT_ID=
# YOUTUBE_CLIENT_SECRET=
